<?xml version="1.0"?>
<!--
/**
 * This is where we customize the checkout page layout.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!--
        STEP 1: INJECT MONEYHASH SDK CDN
        -->
        <script src="https://cdn.jsdelivr.net/npm/@moneyhash/js-sdk@2.4.1/dist/headlessMoneyHash.iife.js" src_type="url"/>
    </head>
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <!-- This is the payment step -->
                                        <item name="billing-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="renders" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <!--
                                                                STEP 2: REGISTER OUR CUSTOM RENDERER
                                                                This tells Magento that when it finds our payment method ('mhcheckout_sdk'),
                                                                it should use our custom JS component to render it.
                                                                -->
                                                                <item name="mhcheckout-sdk-renderer" xsi:type="array">
                                                                    <item name="component" xsi:type="string">MHCheckout_SDK/js/view/payment/sdk-payment</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="mhcheckout_sdk" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                        <!--
                                                        STEP 3: REMOVE OTHER PAYMENT METHODS
                                                        As MoneyHash SDK handles ALL payment options, you can remove 
                                                        the default Magento payment method list completely.
                                                        -->
                                                        <item name="payment-methods-load" xsi:type="array">
                                                            <item name="component" xsi:type="string">MHCheckout_SDK/js/view/payment/sdk-payment</item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
